generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement()) @map("userId") @db.SmallInt
  username  String   @map("userName")
  email     String   @unique @map("Email")
  password  String   @map("password")
  contactNo String?  @map("contactNo")
  role      UserRole @default(NON_ADMIN) @map("role")
  img       String?  @map("img")

  @@map("Management")
}

model Company {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?
  email       String?  @db.VarChar(255)
  tenantCount Int      @default(0) @map("tenant_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")
  servers     Server[]
  customizations Customization[]

  @@map("companyList")
}

model CustomizationSection {
  id          Int                     @id @default(autoincrement())
  name        String                  @db.VarChar(255)
  subsections CustomizationSubsection[]

  @@map("customization_sections")
}

model CustomizationSubsection {
  id             Int                     @id @default(autoincrement())
  sectionId      Int?                    @map("section_id")
  name           String                  @db.VarChar(255)
  section        CustomizationSection?    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  customizations Customization[]

  @@map("customization_subsections")
}

model Customization {
  id           Int                      @id @default(autoincrement())
  subsectionId Int?                     @map("subsection_id")
  companyId    Int?                     @map("company_id")
  name         String                   @db.VarChar(255)
  description  String?
  createdAt    DateTime                 @default(now()) @map("created_at")
  subsection   CustomizationSubsection? @relation(fields: [subsectionId], references: [id])
  company      Company?                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("customization")
}

model CompanyServer {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  ipAddress String   @map("ip_address") @db.Inet
  label     String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("company_servers")
}

model Server {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  ipAddress String   @map("ip_address") @db.Inet
  label     String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("servers")
}

enum UserRole {
  ADMIN
  NON_ADMIN
}
